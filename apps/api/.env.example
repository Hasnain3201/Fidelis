APP_NAME=LIVEY API
ENVIRONMENT=development
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SECRET=

GOOGLE_API_KEY=
SCRAPER_AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash-lite
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ticketmaster Discovery API (apikey query param; consumer key is often used as api key)
TICKETMASTER_CONSUMER_KEY=
# Optional alias supported in code: TICKETMASTER_API_KEY
# Eventbrite: private OAuth token (Authorization: Bearer) from developer settings
EVENTBRITE_API_KEY=
# Optional: organization ID (numeric string) for GET /v3/organizations/{id}/events/ when public search fails
# EVENTBRITE_ORGANIZATION_ID=

FOURSQUARE_SERVICE_API=
FOURSQUARE_CLIENT_ID=
FOURSQUARE_CLIENT_SECRET=