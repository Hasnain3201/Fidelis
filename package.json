{
  "name": "fidelis",
  "private": true,
  "version": "0.1.0",
  "description": "LIVEY monorepo (Next.js + FastAPI + Supabase)",
  "workspaces": [
  "apps/*",
  "packages/*",
  "web"
],
  "scripts": {
    "dev": "echo \"Run npm run dev:web and npm run dev:api in separate terminals\"",
    "dev:web": "npm run dev --workspace @fidelis/web",
    "dev:api": "cd apps/api && python3 -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "build:web": "npm run build --workspace @fidelis/web",
    "lint:web": "npm run lint --workspace @fidelis/web"
  }
}
